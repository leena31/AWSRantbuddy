<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender: send logs to stdout -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Log format: timestamp, level, logger, message -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling file appender (optional, if you want local persistence) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/tmp/rant-app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- rotate daily -->
            <fileNamePattern>/tmp/rant-app-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <!-- Optional: enable FILE logging too -->
        <!-- <appender-ref ref="FILE"/> -->
    </root>

    <!-- Example: set log level for Spring Security -->
    <logger name="org.springframework.security" level="WARN"/>

    <!-- Example: set log level for your app package -->
    <logger name="com.rantbuddy" level="DEBUG"/>

</configuration>